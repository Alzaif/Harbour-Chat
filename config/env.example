# Harbour Chat — copy to .env at repo root for local dev

PORT=3004
CHAT_DB_PATH=./data/chat.db
CHAT_DATA_DIR=./data
CHAT_MAX_ATTACHMENT_BYTES=10485760
CHAT_REQUIRE_HTTPS_FORWARDED_PROTO=true
CHAT_ENABLE_SECURITY_AUDIT_LOG=true
CHAT_QUARANTINE_SUSPICIOUS_ATTACHMENTS=true
# base64 of a 32-byte key (required in production)
CHAT_MASTER_KEY_B64=
CHAT_MASTER_KEY_ID=chat-kek-v1
# shared secret forwarded by trusted edge proxy
CHAT_TRUSTED_PROXY_TOKEN=
CHAT_VOICE_SFU_BASE_URL=http://localhost:4000
CHAT_VOICE_TURN_URLS=stun:stun.l.google.com:19302
CHAT_VOICE_TURN_SECRET=harbour-dev-turn-secret
CHAT_VOICE_TURN_TTL_SECONDS=3600

TRUST_GATEWAY_HEADERS=false
DEV_USER_ID=dev-user
DEV_USER_EMAIL=dev@harbour.local
DEV_USER_DISPLAY_NAME=Dev User

RUST_LOG=info

# Web (Vite)
VITE_HARBOUR_SHELL_URL=http://localhost:5173
VITE_API_PROXY_TARGET=http://localhost:3004
